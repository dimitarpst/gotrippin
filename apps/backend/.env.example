# Copy to `.env` or `.env.local` in this directory (`apps/backend`). Never commit real secrets.

# Supabase (required)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# CORS / public app URL (used in trip invite emails)
FRONTEND_ORIGIN_DEV=http://localhost:3000
FRONTEND_ORIGIN_PROD=https://gotrippin.app
# Optional override for links in emails (no trailing slash). Defaults to FRONTEND_ORIGIN_* if unset.
PUBLIC_APP_URL=

# Brevo transactional email (optional until you send invites)
# Create an API key in Brevo; verify your sender domain / sender email in the dashboard.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=gotrippin
